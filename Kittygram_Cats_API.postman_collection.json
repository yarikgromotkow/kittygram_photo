		{
			"name": "🔐 JWT — Авторизация",
			"item": [
				{
					"name": "Получить токен (POST /auth/jwt/create/)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200 || pm.response.code === 201) {",
									"    var j = pm.response.json();",
									"    pm.collectionVariables.set('token', j.access);",
									"    pm.collectionVariables.set('refresh', j.refresh);",
									"    console.log('Токен сохранён');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/jwt/create/",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"jwt",
								"create",
								""
							]
						}
					}
				},
				{
					"name": "Обновить токен (POST /auth/jwt/refresh/)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200 || pm.response.code === 201) {",
									"    pm.collectionVariables.set('token', pm.response.json().access);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refresh\": \"{{refresh}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/jwt/refresh/",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"jwt",
								"refresh",
								""
							]
						}
					}
				},
