							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    pm.collectionVariables.set('admin_cat_id', String(pm.response.json().id));",
									"    console.log('admin_cat_id сохранён:', pm.response.json().id);",
									"} else {",
									"    console.error('Не удалось создать кошку. Убедитесь, что token — это токен admin.');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
